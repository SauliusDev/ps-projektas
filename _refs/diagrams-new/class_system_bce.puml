@startuml class_system_bce
skinparam style strictuml
skinparam classAttributeIconSize 0
left to right direction

package "Boundary <<boundary>>" {
  class GuestView <<boundary>>
  class TravelerView <<boundary>>
  class AdminView <<boundary>>

  class GuestApiController <<boundary>>
  class TravelerApiController <<boundary>>
  class AdminApiController <<boundary>>
}

package "Control <<control>>" {
  class AuthController <<control>>
  class TripsController <<control>>
  class DealsController <<control>>
  class PlacesController <<control>>
  class FoodController <<control>>
  class UsersController <<control>>
}

package "Entity <<entity>>" {
  class User <<entity>>
  class Admin <<entity>>
  class Traveler <<entity>>
  class Trip <<entity>>
  class Route <<entity>>
  class RouteAttraction <<entity>>
  class RouteFoodPlace <<entity>>
  class Deal <<entity>>
  class FoodPlan <<entity>>
  class Preferences <<entity>>
  class Menu <<entity>>
  class Dish <<entity>>
  class VisitedPlace <<entity>>
  class Group <<entity>>
}

GuestView --> GuestApiController
TravelerView --> TravelerApiController
AdminView --> AdminApiController

GuestApiController --> AuthController
GuestApiController --> DealsController
TravelerApiController --> TripsController
TravelerApiController --> PlacesController
TravelerApiController --> FoodController
AdminApiController --> DealsController
AdminApiController --> PlacesController
AdminApiController --> UsersController

AuthController --> User
TripsController --> Trip
TripsController --> Route
TripsController --> RouteAttraction
TripsController --> RouteFoodPlace
TripsController --> FoodPlan
DealsController --> Deal
PlacesController --> VisitedPlace
PlacesController --> RouteAttraction
FoodController --> FoodPlan
FoodController --> Menu
FoodController --> Dish
UsersController --> User
UsersController --> Traveler
UsersController --> Admin
UsersController --> Preferences
UsersController --> Group

User <|-- Traveler
User <|-- Admin
Trip *-- Route
Trip *-- FoodPlan
Route *-- RouteAttraction
Route *-- RouteFoodPlace
FoodPlan *-- Menu
Menu *-- Dish
Group o-- Traveler
Traveler o-- Preferences
@enduml
