@startuml use_case
!pragma layout smetana
skinparam style strictuml
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}

left to right direction

