actor "El pasto serveris" as El_pasto_serveris
actor "Google maps" as Google_maps
actor "Keliautojas" as Keliautojas
actor "Naudotojas" as Naudotojas
actor "Svecias" as Svecias

Keliautojas --|> Naudotojas
Admin --|> Naudotojas

rectangle "Svečio posistemė" {
