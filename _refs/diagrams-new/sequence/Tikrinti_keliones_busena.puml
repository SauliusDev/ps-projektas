@startuml
skinparam style strictuml

title Tikrinti keliones busena

actor "User" as user
boundary "AdminDashboardView" as ui
control "TripsController" as tripsController
entity "Trip" as trip

user -> ui: Request Tikrinti keliones busena
ui -> tripsController: Forward request
tripsController -> trip: Execute business operation
trip --> tripsController: Return operation result
tripsController --> ui: Build response
ui --> user: Present response
@enduml
