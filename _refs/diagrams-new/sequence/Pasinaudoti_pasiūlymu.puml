@startuml
skinparam style strictuml

title Pasinaudoti pasiūlymu

actor "User" as user
boundary "TravelerTripsView" as ui
control "DealsController" as dealsController
entity "Deal" as deal

user -> ui: Request Pasinaudoti pasiūlymu
ui -> dealsController: Forward request
dealsController -> deal: Execute business operation
deal --> dealsController: Return operation result
dealsController --> ui: Build response
ui --> user: Present response
@enduml
