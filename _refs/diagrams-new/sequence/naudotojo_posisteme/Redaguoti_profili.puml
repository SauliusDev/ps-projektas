@startuml Redaguoti_profili
skinparam style strictuml

actor Keliautojas as A
boundary TravelerProfileView as V
boundary TravelerApi as API
control UserController as C
entity Preferences as E
database UserRepository as R

A -> V : openProfilePage()
V -> API : GET /api/traveler/profile
API -> C : getProfile(travelerId)
C -> R : findWithPreferences(travelerId)
R --> C : user : User
C --> API : user
API --> V : 200 OK { user }
V --> A : renderProfileForm(user)

A -> V : submitProfileChanges(budget, diet, city, tripType)
V -> API : PUT /api/traveler/profile(budget, diet, city, tripType)
API -> C : updateProfile(travelerId, budget, diet, city, tripType)
C -> R : findPreferences(travelerId)
R --> C : prefs : Preferences
C -> E : update(prefs, budget, diet, city, tripType)
E --> C : updatedPrefs : Preferences
C -> R : save(updatedPrefs)
R --> C : saved
C --> API : success
API --> V : 200 OK
V --> A : showSuccess("Profilis atnaujintas")
@enduml
