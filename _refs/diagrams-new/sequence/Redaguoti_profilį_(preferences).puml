@startuml
skinparam style strictuml

title Redaguoti profilį (preferences)

actor "User" as user
boundary "TravelerTripsView" as ui
control "UsersController" as usersController
entity "Preferences" as preferences

user -> ui: Request Redaguoti profilį (preferences)
ui -> usersController: Forward request
usersController -> preferences: Execute business operation
preferences --> usersController: Return operation result
usersController --> ui: Build response
ui --> user: Present response
@enduml
