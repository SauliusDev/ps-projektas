@startuml
skinparam style strictuml

title Sugeneruoti maisto planą

actor "User" as user
boundary "TravelerTripsView" as ui
control "FoodController" as foodController
entity "FoodPlan" as foodPlan

user -> ui: Request Sugeneruoti maisto planą
ui -> foodController: Forward request
foodController -> foodPlan: Execute business operation
foodPlan --> foodController: Return operation result
foodController --> ui: Build response
ui --> user: Present response
@enduml
