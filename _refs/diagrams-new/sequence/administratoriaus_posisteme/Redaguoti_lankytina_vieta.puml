@startuml Redaguoti_lankytina_vieta
skinparam style strictuml

actor Admin as A
boundary AdminPlacesView as V
boundary AdminApi as API
control PlacesController as C
entity Place as E
database PlaceRepository as R

ref over A, V, API, C : Perziureti_lankytinas_vietas

A -> V : selectPlace(placeId)
A -> V : submitEditForm(name, address, city, type, description)
V -> API : PUT /api/admin/places/{placeId}(name, address, city, type, description)
API -> C : updatePlace(placeId, name, address, city, type, description)
C -> R : findById(placeId)
R --> C : place : Place

alt [place found]
  C -> E : applyUpdates(place, name, address, city, type, description)
  E --> C : updatedPlace : Place
  C -> R : save(updatedPlace)
  R --> C : saved
  C --> API : updatedPlace
  API --> V : 200 OK { place }
  V --> A : showSuccess("Lankytina vieta atnaujinta")
else [else]
  C --> API : NotFoundError
  API --> V : 404 Not Found
  V --> A : showError("Lankytina vieta nerasta")
end
@enduml
