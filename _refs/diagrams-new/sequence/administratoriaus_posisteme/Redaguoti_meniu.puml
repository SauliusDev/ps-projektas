@startuml Redaguoti_meniu
skinparam style strictuml

actor Admin as A
boundary AdminMenuView as V
boundary AdminApi as API
control FoodController as C
entity Menu as E
database FoodRepository as R

ref over A, V, API, C : Perziureti_meniu

A -> V : selectMenu(menuId)
A -> V : submitEditForm(type)
V -> API : PUT /api/admin/menus/{menuId}(type)
API -> C : updateMenu(menuId, type)
C -> R : findById(menuId)
R --> C : menu : Menu

alt [menu found]
  C -> E : applyUpdates(menu, type)
  E --> C : updated : Menu
  C -> R : save(updated)
  R --> C : saved
  C --> API : updated
  API --> V : 200 OK { menu }
  V --> A : showSuccess("Meniu atnaujintas")
else [else]
  C --> API : NotFoundError
  API --> V : 404 Not Found
  V --> A : showError("Meniu nerastas")
end
@enduml
