@startuml Sukurti_pasiulyma
skinparam style strictuml

actor Admin as A
boundary AdminDealsView as V
boundary AdminApi as API
control DealController as C
entity Deal as E
database DealRepository as R

ref over A, V, API, C : Perziureti_pasiulymus_Admin

A -> V : openCreateDealForm()
A -> V : submitDealForm(title, discount, popularity, rating)
V -> API : POST /api/admin/deals(title, discount, popularity, rating)
API -> C : createDeal(title, discount, popularity, rating)
C -> E : buildDeal(title, discount, popularity, rating)
E --> C : deal : Deal
C -> R : save(deal)
R --> C : saved : Deal
C --> API : saved
API --> V : 201 Created { dealId }
V --> A : showSuccess("Pasiūlymas sukurtas")
@enduml
