@startuml Istrinti_maisto_vieta
skinparam style strictuml

actor Admin as A
boundary AdminFoodView as V
boundary AdminApi as API
control FoodController as C
database FoodRepository as R

ref over A, V, API, C : Perziureti_maisto_vietas

A -> V : selectFoodPlace(foodPlaceId)
A -> V : confirmDelete()
V -> API : DELETE /api/admin/food-places/{foodPlaceId}
API -> C : deleteFoodPlace(foodPlaceId)
C -> R : findById(foodPlaceId)
R --> C : foodPlace : FoodPlace

alt [food place found]
  C -> R : delete(foodPlaceId)
  R --> C : deleted
  C --> API : success
  API --> V : 204 No Content
  V --> A : showSuccess("Maisto vieta ištrinta")
else [else]
  C --> API : NotFoundError
  API --> V : 404 Not Found
  V --> A : showError("Maisto vieta nerasta")
end
@enduml
