@startuml Perziureti_pasiulymus_Admin
skinparam style strictuml

actor Admin as A
boundary AdminDealsView as V
boundary AdminApi as API
control DealController as C
database DealRepository as R

A -> V : openDealsManager()
V -> API : GET /api/admin/deals
API -> C : listDeals()
C -> R : findAll()
R --> C : deals : Deal[]
C --> API : deals
API --> V : 200 OK { items : Deal[] }
V --> A : renderDealsTable(deals)

opt [create deal]
  ref over A, V, API, C : Sukurti_pasiulyma
end

opt [edit deal]
  ref over A, V, API, C : Redaguoti_pasiulyma
end

opt [delete deal]
  ref over A, V, API, C : Trinti_pasiulyma
end
@enduml
