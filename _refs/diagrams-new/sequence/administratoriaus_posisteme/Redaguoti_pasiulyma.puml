@startuml Redaguoti_pasiulyma
skinparam style strictuml

actor Admin as A
boundary AdminDealsView as V
boundary AdminApi as API
control DealController as C
entity Deal as E
database DealRepository as R

ref over A, V, API, C : Perziureti_pasiulymus_Admin

A -> V : selectDeal(dealId)
A -> V : submitEditForm(title, discount, popularity, rating)
V -> API : PUT /api/admin/deals/{dealId}(title, discount, popularity, rating)
API -> C : updateDeal(dealId, title, discount, popularity, rating)
C -> R : findById(dealId)
R --> C : deal : Deal

alt [deal found]
  C -> E : applyUpdates(deal, title, discount, popularity, rating)
  E --> C : updated : Deal
  C -> R : save(updated)
  R --> C : saved
  C --> API : updated
  API --> V : 200 OK { deal }
  V --> A : showSuccess("Pasiūlymas atnaujintas")
else [else]
  C --> API : NotFoundError
  API --> V : 404 Not Found
  V --> A : showError("Pasiūlymas nerastas")
end
@enduml
