@startuml Perziureti_pasiulymus
skinparam style strictuml

actor Svecias as A
boundary GuestDealsView as V
boundary GuestApi as API
control DealController as C
database DealRepository as R

A -> V : openDealsPage()
V -> API : GET /api/guest/deals
API -> C : listDeals()
C -> R : findAll()
R --> C : deals : Deal[]

ref over C, R : Rekomenduoti_pasiulymus

C --> API : deals : Deal[]
API --> V : 200 OK { items : Deal[] }
V --> A : renderDeals(deals)
@enduml
