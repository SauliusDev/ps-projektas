@startuml Prisijungti
skinparam style strictuml

actor Svecias as A
boundary GuestAuthView as V
boundary GuestApi as API
control AuthController as C
entity User as E
database UserRepository as R

A -> V : enterCredentials(email, password)
V -> API : POST /api/guest/login(email, password)
API -> C : authenticate(email, password)
C -> R : findByEmail(email)
R --> C : user : User

alt [credentials valid]
  C -> E : verifyPassword(password)
  E --> C : valid : Boolean
  C -> C : generateToken(user)
  C --> API : token : String
  API --> V : 200 OK { token }
  V --> A : navigateToHome()
else [else]
  C --> API : AuthError
  API --> V : 401 Unauthorized
  V --> A : showError("Neteisingi prisijungimo duomenys")
end
@enduml
