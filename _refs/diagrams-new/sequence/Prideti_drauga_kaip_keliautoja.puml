@startuml
skinparam style strictuml

title Prideti drauga kaip keliautoja

actor "User" as user
boundary "TravelerTripsView" as ui
control "TripsController" as tripsController
entity "Trip" as trip

user -> ui: Request Prideti drauga kaip keliautoja
