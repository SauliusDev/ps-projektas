@startuml
skinparam style strictuml

title Pasirinkti kelionės objektus

actor "User" as user
boundary "TravelerTripsView" as ui
control "PlacesController" as placesController
entity "RouteAttraction" as routeAttraction

user -> ui: Request Pasirinkti kelionės objektus
ui -> placesController: Forward request
placesController -> routeAttraction: Execute business operation
routeAttraction --> placesController: Return operation result
placesController --> ui: Build response
ui --> user: Present response
@enduml
