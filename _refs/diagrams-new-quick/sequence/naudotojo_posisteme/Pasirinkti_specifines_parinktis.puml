@startuml Pasirinkti_specifines_parinktis
skinparam style strictuml

actor Keliautojas as A
boundary JourneyParamsView as V
control JourneyController as FEC
control "JourneyController" as BEC
entity Preferences as E

A -> V : openParamsForm(tripId)
V -> FEC : loadPreferences(travelerId)
FEC -> BEC : findPreferences(travelerId)
BEC -> E : findByTraveler(travelerId)
E --> BEC : prefs : Preferences
BEC --> FEC : prefs : Preferences
FEC --> V : render(prefs)

A -> V : setJourneyParams(budget, interests, pace)
V -> FEC : saveParams(tripId, budget, interests, pace)
FEC -> BEC : saveJourneyParams(tripId, budget, interests, pace)
BEC -> E : save(tripId, budget, interests, pace)
E --> BEC : prefs : Preferences
BEC --> FEC : prefs : Preferences
FEC --> V : paramsSaved()
V --> A : showConfirmation()
@enduml
