@startuml Pasirinkti_keliones_objektus
skinparam style strictuml

actor Keliautojas as A
actor "Google maps" as GM
boundary AddressInputView as V
control RouteController as FEC
control "RouteController" as BEC
entity RoutePlace as E

A -> V : searchPlaces(city, category)
V -> FEC : findPlaces(city, category)
FEC -> BEC : findPlaces(city, category)
BEC -> GM : searchNearby(city, category)
GM --> BEC : places
BEC -> E : findAll(tripId)
E --> BEC : savedPlaces : RoutePlace[]
BEC --> FEC : places
FEC --> V : render(places, savedPlaces)
V --> A : showPlacesList(places)

A -> V : selectPlace(placeId)
V -> FEC : addPlace(tripId, placeId)
FEC -> BEC : addPlaceToTrip(tripId, placeId)
BEC -> E : save(tripId, placeId)
E --> BEC : routePlace : RoutePlace
BEC --> FEC : ok
FEC --> V : placeAdded()
V --> A : showPlaceSelected(placeId)
@enduml
