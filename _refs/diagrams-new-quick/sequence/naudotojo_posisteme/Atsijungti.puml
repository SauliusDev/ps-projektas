@startuml Atsijungti
skinparam style strictuml

actor Naudotojas as A
boundary MainView as V
control UserController as FEC
control AuthController as BEC
entity User as E

A -> V : clickLogout()
V -> FEC : logout()
FEC -> BEC : invalidateSession(token)
BEC -> E : findByToken(token)
E --> BEC : user : User
BEC -> E : clearToken(user)
E --> BEC : ok
BEC --> FEC : ok
FEC --> V : sessionCleared()
V --> A : navigateToLogin()
@enduml
