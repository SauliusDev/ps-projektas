@startuml Perziureti_kelia_zemelapy
skinparam style strictuml

actor Keliautojas as A
actor "Google maps" as GM
boundary JourneyOverviewView as V
control RouteController as FEC
control "RouteController" as BEC
entity Route as E

ref over A, V, FEC, BEC : Perziureti_keliones

A -> V : openMapView(tripId)
V -> FEC : loadRoute(tripId)
FEC -> BEC : findByTrip(tripId)
BEC -> E : findByTripId(tripId)
E --> BEC : route : Route
BEC -> GM : renderMap(route)
GM --> BEC : mapUrl
BEC --> FEC : route, mapUrl
FEC --> V : render(route, mapUrl)
V --> A : showMap(mapUrl)
@enduml
