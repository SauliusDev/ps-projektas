@startuml Redaguoti_profili
skinparam style strictuml

actor Keliautojas as A
boundary MainView as V
control UserController as FEC
control "UserController" as BEC
entity Preferences as E

A -> V : openProfileSettings()
V -> FEC : loadProfile(travelerId)
FEC -> BEC : findProfile(travelerId)
BEC -> E : findByTraveler(travelerId)
E --> BEC : prefs : Preferences
BEC --> FEC : prefs : Preferences
FEC --> V : render(prefs)

A -> V : submitProfileChanges(diet, interests, budget)
V -> FEC : updateProfile(travelerId, diet, interests, budget)
FEC -> BEC : updatePreferences(travelerId, diet, interests, budget)
BEC -> E : findByTraveler(travelerId)
E --> BEC : prefs : Preferences
BEC -> E : save(updatedPrefs)
E --> BEC : prefs : Preferences
BEC --> FEC : prefs : Preferences
FEC --> V : profileUpdated(prefs)
V --> A : showSuccess("Profilis atnaujintas")
@enduml
