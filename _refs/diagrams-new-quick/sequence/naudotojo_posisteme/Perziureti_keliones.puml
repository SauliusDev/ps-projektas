@startuml Perziureti_keliones
skinparam style strictuml

actor Keliautojas as A
boundary TripListView as V
control TripListController as FEC
control TripController as BEC
entity Trip as E

A -> V : openTripsPage()
V -> FEC : loadTrips()
FEC -> BEC : findAllByTraveler(travelerId)
BEC -> E : findAllByTraveler(travelerId)
E --> BEC : trips : Trip[]
BEC --> FEC : trips : Trip[]
FEC --> V : render(trips)
V --> A : showTripList(trips)
@enduml
