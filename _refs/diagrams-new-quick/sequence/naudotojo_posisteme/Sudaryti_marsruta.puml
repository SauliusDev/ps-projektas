@startuml Sudaryti_marsruta
skinparam style strictuml

actor Keliautojas as A
actor "Google maps" as GM
boundary AddressInputView as V
control RouteController as FEC
control "RouteController" as BEC
entity Route as E

A -> V : enterStartAddress(address)
V -> FEC : buildRoute(tripId, startAddress)
FEC -> BEC : generateRoute(tripId, startAddress)
BEC -> GM : requestRoute(startAddress, waypoints)
GM --> BEC : routeData
BEC -> E : save(tripId, routeData)
E --> BEC : route : Route
BEC --> FEC : route : Route
FEC --> V : render(route)
V --> A : showRouteOnMap(route)
@enduml
