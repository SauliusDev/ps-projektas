@startuml Sujungti_dvieju_keliautoju_parinktis
skinparam style strictuml

actor Keliautojas as A
boundary JourneyParamsView as V
control JourneyController as FEC
control "JourneyController" as BEC
entity Preferences as E

A -> V : openMergePrefsView(tripId)
V -> FEC : loadTravelers(tripId)
FEC -> BEC : getTravelers(tripId)
BEC -> E : findAllByTrip(tripId)
E --> BEC : prefs : Preferences[]
BEC --> FEC : prefs : Preferences[]
FEC --> V : render(prefs)

A -> V : confirmMerge()
V -> FEC : mergePreferences(tripId)
FEC -> BEC : mergePreferences(tripId)
BEC -> E : findAllByTrip(tripId)
E --> BEC : allPrefs : Preferences[]
BEC -> E : save(mergedPrefs)
E --> BEC : merged : Preferences
BEC --> FEC : merged : Preferences
FEC --> V : mergeComplete(merged)
V --> A : showMergedPreferences(merged)
@enduml
