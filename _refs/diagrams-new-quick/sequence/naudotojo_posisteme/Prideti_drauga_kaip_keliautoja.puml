@startuml Prideti_drauga_kaip_keliautoja
skinparam style strictuml

actor Keliautojas as A
boundary AddFriendView as V
control UserController as FEC
control "UserController" as BEC
entity Traveler as E

A -> V : openAddFriendForm(tripId)
A -> V : enterFriendEmail(email)
V -> FEC : findFriend(email)
FEC -> BEC : findUserByEmail(email)
BEC -> E : findByEmail(email)
E --> BEC : traveler : Traveler

alt [friend found]
  BEC --> FEC : traveler : Traveler
  FEC --> V : showFriendPreview(traveler)
  A -> V : confirmAdd()
  V -> FEC : addToTrip(tripId, travelerId)
  FEC -> BEC : addTravelerToTrip(tripId, travelerId)
  BEC -> E : save(tripId, travelerId)
  E --> BEC : ok
  BEC --> FEC : ok
  FEC --> V : friendAdded()
  V --> A : showSuccess("Draugas pridėtas")
else [else]
  BEC --> FEC : NotFoundError
  FEC --> V : showError()
  V --> A : showError("Naudotojas nerastas")
end
@enduml
