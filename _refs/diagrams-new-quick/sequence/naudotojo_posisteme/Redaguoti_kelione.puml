@startuml Redaguoti_kelione
skinparam style strictuml

actor Keliautojas as A
boundary TripEditView as V
control TripListController as FEC
control TripController as BEC
entity Trip as E

ref over A, V, FEC, BEC : Perziureti_keliones

A -> V : openEditForm(tripId)
A -> V : submitChanges(title, city, startDate, endDate)
V -> FEC : updateTrip(tripId, title, city, startDate, endDate)
FEC -> BEC : updateTrip(tripId, title, city, startDate, endDate)
BEC -> E : findById(tripId)
E --> BEC : trip : Trip
BEC -> E : save(updatedTrip)
E --> BEC : trip : Trip
BEC --> FEC : trip : Trip
FEC --> V : tripUpdated(trip)
V --> A : showSuccess("Kelionė atnaujinta")
@enduml
