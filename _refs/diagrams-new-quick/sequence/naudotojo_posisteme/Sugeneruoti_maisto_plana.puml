@startuml Sugeneruoti_maisto_plana
skinparam style strictuml

actor Keliautojas as A
boundary CreateJourneyView as V
control JourneyController as FEC
control FoodController as BEC
entity FoodPlan as E

A -> V : requestFoodPlan(tripId)
V -> FEC : generateFoodPlan(tripId)
FEC -> BEC : generatePlan(tripId)
BEC -> E : findByTrip(tripId)
E --> BEC : existing : FoodPlan
BEC -> E : save(generatedPlan)
E --> BEC : plan : FoodPlan
BEC --> FEC : plan : FoodPlan
FEC --> V : render(plan)
V --> A : showFoodPlan(plan)
@enduml
