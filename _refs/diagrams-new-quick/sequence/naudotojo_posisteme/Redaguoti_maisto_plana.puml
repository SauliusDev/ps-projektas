@startuml Redaguoti_maisto_plana
skinparam style strictuml

actor Keliautojas as A
boundary TripEditView as V
control TripListController as FEC
control FoodController as BEC
entity FoodPlan as E

ref over A, V, FEC, BEC : Perziureti_keliones

A -> V : openFoodPlanEditor(tripId)
V -> FEC : loadFoodPlan(tripId)
FEC -> BEC : findPlanByTrip(tripId)
BEC -> E : findByTripId(tripId)
E --> BEC : plan : FoodPlan
BEC --> FEC : plan : FoodPlan
FEC --> V : render(plan)

A -> V : editPlan(changes)
V -> FEC : updateFoodPlan(tripId, changes)
FEC -> BEC : updatePlan(tripId, changes)
BEC -> E : findById(plan.id)
E --> BEC : plan : FoodPlan
BEC -> E : save(updatedPlan)
E --> BEC : plan : FoodPlan
BEC --> FEC : plan : FoodPlan
FEC --> V : planUpdated(plan)
V --> A : showSuccess("Maisto planas atnaujintas")
@enduml
