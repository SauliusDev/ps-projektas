@startuml Kurti_kelione
skinparam style strictuml

actor Keliautojas as A
boundary TripEditView as V
control TripListController as FEC
control TripController as BEC
entity Trip as E

A -> V : openNewTripForm()
A -> V : submitTripForm(title, city, startDate, endDate)
V -> FEC : createTrip(title, city, startDate, endDate)
FEC -> BEC : createTrip(title, city, startDate, endDate, travelerId)
BEC -> E : save(title, city, startDate, endDate, travelerId)
E --> BEC : trip : Trip
BEC --> FEC : trip : Trip
FEC --> V : tripCreated(trip)

opt [add friend]
  ref over A, V, FEC, BEC : Prideti_drauga_kaip_keliautoja
end

opt [set journey params]
  ref over A, V, FEC, BEC : Pasirinkti_specifines_parinktis
end

ref over A, V, FEC, BEC : Sudaryti_marsruta

opt [generate food plan]
  ref over A, V, FEC, BEC : Sugeneruoti_maisto_plana
end

V --> A : navigateToTripDetail(trip)
@enduml
