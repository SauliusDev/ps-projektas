@startuml Pasinaudoti_pasiulymu
skinparam style strictuml

actor Keliautojas as A
boundary SavedDealsView as V
control SavedDealsController as FEC
control DealController as BEC
entity Deal as E

A -> V : openSavedDeals()
V -> FEC : loadSavedDeals(travelerId)
FEC -> BEC : findSavedByTraveler(travelerId)
BEC -> E : findSavedByTraveler(travelerId)
E --> BEC : deals : Deal[]
BEC --> FEC : deals : Deal[]
FEC --> V : render(deals)
V --> A : showSavedDeals(deals)

A -> V : useDeal(dealId)
V -> FEC : redeemDeal(dealId, travelerId)
FEC -> BEC : redeemDeal(dealId, travelerId)
BEC -> E : findById(dealId)
E --> BEC : deal : Deal

alt [deal valid]
  BEC -> E : save(deal, redeemed=true)
  E --> BEC : ok
  BEC --> FEC : redemptionCode
  FEC --> V : showRedemptionCode(redemptionCode)
  V --> A : showCode(redemptionCode)
else [else]
  BEC --> FEC : InvalidDealError
  FEC --> V : showError()
  V --> A : showError("Pasiūlymas nebegalioja")
end
@enduml
