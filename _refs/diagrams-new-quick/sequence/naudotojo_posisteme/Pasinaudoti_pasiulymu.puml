@startuml Pasinaudoti_pasiulymu
skinparam style strictuml

actor Keliautojas as A
boundary TravelerTripsView as V
boundary TravelerApi as API
control DealsController as C
entity Deal as E

A -> V : openDeal(dealId)
V -> API : GET /api/traveler/deals/{dealId}
API -> C : getDeal(dealId)
C -> E : findById(dealId)
E --> C : deal : Deal

alt [deal found and active]
  C -> E : applyToTraveler(deal, travelerId)
  E --> C : result : DealApplication
  C --> API : result
  API --> V : 200 OK { discount }
  V --> A : showDealApplied(discount)
else [else]
  C --> API : NotFoundError
  API --> V : 404 Not Found
  V --> A : showError("Pasiūlymas nebegalimas")
end
@enduml
