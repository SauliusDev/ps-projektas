@startuml Perziureti_visas_keliones
skinparam style strictuml

actor Admin as A
boundary AdminTripsView as V
boundary AdminApi as API
control TripQueryController as C
entity TripRepository as R

A -> V : openAllTripsManager()
V -> API : GET /api/admin/trips
API -> C : listAllTrips()
C -> R : findAll()
R --> C : trips : Trip[]
C --> API : trips
API --> V : 200 OK { items : Trip[] }
V --> A : renderTripsTable(trips)

opt [inspect trip status]
  ref over A, V, API, C : Tikrinti_keliones_busena
end
@enduml
