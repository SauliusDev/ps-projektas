@startuml Tikrinti_keliones_busena
skinparam style strictuml

actor Admin as A
boundary TripListView as V
control TripListController as FEC
control AdminController as BEC
entity Trip as E

ref over A, V, FEC, BEC : Perziureti_visas_keliones

A -> V : selectTrip(tripId)
V -> FEC : loadTripStatus(tripId)
FEC -> BEC : getTripStatus(tripId)
BEC -> E : findById(tripId)
E --> BEC : trip : Trip
BEC --> FEC : status : TripStatus
FEC --> V : render(status)
V --> A : showTripStatus(status)
@enduml
