@startuml Redaguoti_meniu
skinparam style strictuml

actor Admin as A
boundary MainView as V
control JourneyController as FEC
control FoodController as BEC
entity Menu as E

ref over A, V, FEC, BEC : Perziureti_meniu

A -> V : openEditMenuForm(menuId)
A -> V : submitChanges(name, description)
V -> FEC : updateMenu(menuId, name, description)
FEC -> BEC : updateMenu(menuId, name, description)
BEC -> E : findById(menuId)
E --> BEC : menu : Menu
BEC -> E : save(updatedMenu)
E --> BEC : menu : Menu
BEC --> FEC : menu : Menu
FEC --> V : menuUpdated(menu)
V --> A : showSuccess("Meniu atnaujintas")
@enduml
