@startuml Redaguoti_patiekala
skinparam style strictuml

actor Admin as A
boundary MainView as V
control JourneyController as FEC
control FoodController as BEC
entity Dish as E

ref over A, V, FEC, BEC : Perziureti_patiekalus

A -> V : openEditDishForm(dishId)
A -> V : submitChanges(name, description, price)
V -> FEC : updateDish(dishId, name, description, price)
FEC -> BEC : updateDish(dishId, name, description, price)
BEC -> E : findById(dishId)
E --> BEC : dish : Dish
BEC -> E : save(updatedDish)
E --> BEC : dish : Dish
BEC --> FEC : dish : Dish
FEC --> V : dishUpdated(dish)
V --> A : showSuccess("Patiekalas atnaujintas")
@enduml
