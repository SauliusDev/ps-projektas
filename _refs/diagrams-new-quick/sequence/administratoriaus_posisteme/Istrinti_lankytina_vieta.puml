@startuml Istrinti_lankytina_vieta
skinparam style strictuml

actor Admin as A
boundary MainView as V
control RouteController as FEC
control PlaceController as BEC
entity RoutePlace as E

ref over A, V, FEC, BEC : Perziureti_lankytinas_vietas

A -> V : selectPlace(placeId)
A -> V : confirmDelete()
V -> FEC : deletePlace(placeId)
FEC -> BEC : deletePlace(placeId)
BEC -> E : findById(placeId)
E --> BEC : place : RoutePlace
BEC -> E : delete(placeId)
E --> BEC : ok
BEC --> FEC : ok
FEC --> V : placeDeleted()
V --> A : showSuccess("Lankytina vieta ištrinta")
@enduml
