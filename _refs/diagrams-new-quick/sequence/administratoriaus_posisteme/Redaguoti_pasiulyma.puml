@startuml Redaguoti_pasiulyma
skinparam style strictuml

actor Admin as A
boundary DealsView as V
control DealController as FEC
control "DealController" as BEC
entity Deal as E

ref over A, V, FEC, BEC : Perziureti_pasiulymus

A -> V : openEditDealForm(dealId)
A -> V : submitChanges(title, discount, expiry)
V -> FEC : updateDeal(dealId, title, discount, expiry)
FEC -> BEC : updateDeal(dealId, title, discount, expiry)
BEC -> E : findById(dealId)
E --> BEC : deal : Deal
BEC -> E : save(updatedDeal)
E --> BEC : deal : Deal
BEC --> FEC : deal : Deal
FEC --> V : dealUpdated(deal)
V --> A : showSuccess("Pasiūlymas atnaujintas")
@enduml
