@startuml Sukurti_pasiulyma
skinparam style strictuml

actor Admin as A
boundary DealsView as V
control DealController as FEC
control "DealController" as BEC
entity Deal as E

ref over A, V, FEC, BEC : Perziureti_pasiulymus

A -> V : openCreateDealForm()
A -> V : submitDealForm(title, discount, expiry, placeId)
V -> FEC : createDeal(title, discount, expiry, placeId)
FEC -> BEC : createDeal(title, discount, expiry, placeId)
BEC -> E : save(title, discount, expiry, placeId)
E --> BEC : deal : Deal
BEC --> FEC : deal : Deal
FEC --> V : dealCreated(deal)
V --> A : showSuccess("Pasiūlymas sukurtas")
@enduml
