@startuml Prideti_meniu
skinparam style strictuml

actor Admin as A
boundary AdminMenuView as V
boundary AdminApi as API
control FoodController as C
entity Menu as E
entity FoodRepository as R

ref over A, V, API, C : Perziureti_meniu

A -> V : openAddMenuForm()
A -> V : submitMenuForm(type, foodPlaceId)
V -> API : POST /api/admin/food-places/{foodPlaceId}/menus(type)
API -> C : createMenu(foodPlaceId, type)
C -> E : buildMenu(foodPlaceId, type)
E --> C : menu : Menu
C -> R : save(menu)
R --> C : saved : Menu
C --> API : saved
API --> V : 201 Created { menuId }
V --> A : showSuccess("Meniu pridėtas")
@enduml
