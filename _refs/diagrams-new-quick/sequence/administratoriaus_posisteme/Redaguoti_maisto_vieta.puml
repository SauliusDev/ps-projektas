@startuml Redaguoti_maisto_vieta
skinparam style strictuml

actor Admin as A
boundary MainView as V
control JourneyController as FEC
control FoodController as BEC
entity RouteFoodPlace as E

ref over A, V, FEC, BEC : Perziureti_maisto_vietas

A -> V : openEditFoodPlaceForm(placeId)
A -> V : submitChanges(name, address, cuisine)
V -> FEC : updateFoodPlace(placeId, name, address, cuisine)
FEC -> BEC : updateFoodPlace(placeId, name, address, cuisine)
BEC -> E : findById(placeId)
E --> BEC : place : RouteFoodPlace
BEC -> E : save(updatedPlace)
E --> BEC : place : RouteFoodPlace
BEC --> FEC : place : RouteFoodPlace
FEC --> V : placeUpdated(place)
V --> A : showSuccess("Maisto vieta atnaujinta")
@enduml
