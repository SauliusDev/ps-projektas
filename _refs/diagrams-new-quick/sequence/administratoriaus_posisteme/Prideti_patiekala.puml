@startuml Prideti_patiekala
skinparam style strictuml

actor Admin as A
boundary MainView as V
control JourneyController as FEC
control FoodController as BEC
entity Dish as E

ref over A, V, FEC, BEC : Perziureti_patiekalus

A -> V : openAddDishForm(menuId)
A -> V : submitDishForm(name, description, price, menuId)
V -> FEC : addDish(name, description, price, menuId)
FEC -> BEC : createDish(name, description, price, menuId)
BEC -> E : save(name, description, price, menuId)
E --> BEC : dish : Dish
BEC --> FEC : dish : Dish
FEC --> V : dishAdded(dish)
V --> A : showSuccess("Patiekalas pridėtas")
@enduml
