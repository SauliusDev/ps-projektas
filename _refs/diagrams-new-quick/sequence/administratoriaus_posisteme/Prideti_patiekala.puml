@startuml Prideti_patiekala
skinparam style strictuml

actor Admin as A
boundary AdminMenuView as V
boundary AdminApi as API
control FoodController as C
entity Dish as E
entity FoodRepository as R

ref over A, V, API, C : Perziureti_patiekalus

A -> V : openAddDishForm()
A -> V : submitDishForm(name, diet, description, menuId)
V -> API : POST /api/admin/menus/{menuId}/dishes(name, diet, description)
API -> C : createDish(menuId, name, diet, description)
C -> E : buildDish(menuId, name, diet, description)
E --> C : dish : Dish
C -> R : save(dish)
R --> C : saved : Dish
C --> API : saved
API --> V : 201 Created { dishId }
V --> A : showSuccess("Patiekalas pridėtas")
@enduml
