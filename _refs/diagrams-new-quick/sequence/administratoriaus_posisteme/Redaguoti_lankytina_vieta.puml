@startuml Redaguoti_lankytina_vieta
skinparam style strictuml

actor Admin as A
boundary MainView as V
control RouteController as FEC
control PlaceController as BEC
entity RoutePlace as E

ref over A, V, FEC, BEC : Perziureti_lankytinas_vietas

A -> V : openEditPlaceForm(placeId)
A -> V : submitChanges(name, address, type, description)
V -> FEC : updatePlace(placeId, name, address, type, description)
FEC -> BEC : updatePlace(placeId, name, address, type, description)
BEC -> E : findById(placeId)
E --> BEC : place : RoutePlace
BEC -> E : save(updatedPlace)
E --> BEC : place : RoutePlace
BEC --> FEC : place : RoutePlace
FEC --> V : placeUpdated(place)
V --> A : showSuccess("Lankytina vieta atnaujinta")
@enduml
