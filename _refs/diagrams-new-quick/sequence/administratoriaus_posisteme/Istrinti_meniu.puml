@startuml Istrinti_meniu
skinparam style strictuml

actor Admin as A
boundary MainView as V
control JourneyController as FEC
control FoodController as BEC
entity Menu as E

ref over A, V, FEC, BEC : Perziureti_meniu

A -> V : selectMenu(menuId)
A -> V : confirmDelete()
V -> FEC : deleteMenu(menuId)
FEC -> BEC : deleteMenu(menuId)
BEC -> E : findById(menuId)
E --> BEC : menu : Menu
BEC -> E : delete(menuId)
E --> BEC : ok
BEC --> FEC : ok
FEC --> V : menuDeleted()
V --> A : showSuccess("Meniu ištrintas")
@enduml
