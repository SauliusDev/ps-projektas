@startuml Trinti_pasiulyma
skinparam style strictuml

actor Admin as A
boundary DealsView as V
control DealController as FEC
control "DealController" as BEC
entity Deal as E

ref over A, V, FEC, BEC : Perziureti_pasiulymus

A -> V : selectDeal(dealId)
A -> V : confirmDelete()
V -> FEC : deleteDeal(dealId)
FEC -> BEC : deleteDeal(dealId)
BEC -> E : findById(dealId)
E --> BEC : deal : Deal
BEC -> E : delete(dealId)
E --> BEC : ok
BEC --> FEC : ok
FEC --> V : dealDeleted()
V --> A : showSuccess("Pasiūlymas ištrintas")
@enduml
