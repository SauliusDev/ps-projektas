@startuml Prisijungti
skinparam style strictuml

actor Svecias as A
boundary MainView as V
control UserController as FEC
control AuthController as BEC
entity User as E

A -> V : enterCredentials(email, password)
V -> FEC : login(email, password)
FEC -> BEC : authenticate(email, password)
BEC -> E : findByEmail(email)
E --> BEC : user : User

alt [credentials valid]
  BEC -> E : verifyPassword(password)
  E --> BEC : valid : Boolean
  BEC --> FEC : token : String
  FEC --> V : loginSuccess(token)
  V --> A : navigateToHome()
else [else]
  BEC --> FEC : AuthError
  FEC --> V : showError()
  V --> A : showError("Neteisingi prisijungimo duomenys")
end
@enduml
