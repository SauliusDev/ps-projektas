@startuml Registruotis
skinparam style strictuml

actor Svecias as A
boundary MainView as V
control UserController as FEC
control AuthController as BEC
entity User as E

A -> V : fillRegistrationForm(name, email, password)
V -> FEC : register(name, email, password)
FEC -> BEC : createUser(name, email, password)
BEC -> E : findByEmail(email)
E --> BEC : existing : User

alt [email not taken]
  BEC -> E : save(name, email, hashedPassword)
  E --> BEC : newUser : User
  BEC --> FEC : token : String
  FEC --> V : registrationSuccess(token)
  V --> A : navigateToHome()
else [else]
  BEC --> FEC : ConflictError
  FEC --> V : showError()
  V --> A : showError("El. paštas jau užregistruotas")
end
@enduml
