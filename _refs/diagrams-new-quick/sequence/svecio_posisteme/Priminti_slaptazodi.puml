@startuml Priminti_slaptazodi
skinparam style strictuml

actor Svecias as A
boundary GuestAuthView as V
boundary GuestApi as API
control AuthController as C
entity User as E
actor "El pasto serveris" as Email

A -> V : enterEmail(email)
V -> API : POST /api/guest/forgot-password(email)
API -> C : requestPasswordReset(email)
C -> E : findByEmail(email)
E --> C : user : User

alt [user found]
  C -> C : generateResetToken()
  C -> Email : sendResetEmail(email, token)
  Email --> C : sent : Boolean
  C --> API : success
else [else]
  C --> API : success
end

API --> V : 200 OK
V --> A : showMessage("Patikrinkite el. paštą")

opt [user clicks reset link]
  ref over A, V, API, C : Prisijungti
end
@enduml
