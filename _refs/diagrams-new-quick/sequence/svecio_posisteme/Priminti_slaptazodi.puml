@startuml Priminti_slaptazodi
skinparam style strictuml

actor Svecias as A
actor "El pasto serveris" as Email
boundary MainView as V
control UserController as FEC
control AuthController as BEC
entity User as E

A -> V : enterEmail(email)
V -> FEC : forgotPassword(email)
FEC -> BEC : initiatePasswordReset(email)
BEC -> E : findByEmail(email)
E --> BEC : user : User

alt [user found]
  BEC -> E : save(resetToken, expiry)
  E --> BEC : ok
  BEC -> Email : sendResetEmail(email, resetToken)
  Email --> BEC : sent
  BEC --> FEC : ok
  FEC --> V : showConfirmation()
  V --> A : showMessage("Laiškas išsiųstas")
else [else]
  BEC --> FEC : NotFoundError
  FEC --> V : showError()
  V --> A : showError("Naudotojas nerastas")
end
@enduml
