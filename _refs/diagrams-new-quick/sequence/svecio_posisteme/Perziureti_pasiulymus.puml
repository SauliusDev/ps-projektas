@startuml Perziureti_pasiulymus
skinparam style strictuml

actor Svecias as A
boundary GuestDealsView as V
boundary GuestApi as API
control DealsController as C
entity Deal as E

A -> V : openDealsPage()
V -> API : GET /api/guest/deals
API -> C : listDeals()
C -> E : findAll()
E --> C : deals : Deal[]

ref over C, E : Rekomenduoti_pasiulymus

C --> API : deals : Deal[]
API --> V : 200 OK { items : Deal[] }
V --> A : renderDeals(deals)
@enduml
