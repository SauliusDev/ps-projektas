@startuml Perziureti_pasiulymus
skinparam style strictuml

actor Svecias as A
boundary DealsView as V
control DealController as FEC
control "DealController" as BEC
entity Deal as E

A -> V : openDealsPage()
V -> FEC : loadDeals()
FEC -> BEC : findAll()
BEC -> E : findAll()
E --> BEC : deals : Deal[]
BEC -> E : recommendDeals(deals)
E --> BEC : recommended : Deal[]
BEC --> FEC : deals : Deal[]
FEC --> V : render(deals)
V --> A : showDeals(deals)
@enduml
