@startuml Redaguoti_maisto_plana
skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam participant {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam boundary {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam control {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam entity {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
}

title Redaguoti maisto planą — sequence diagram

actor Keliautojas as KT

boundary "FoodPlanView\n<<boundary>>" as FPV
boundary "FoodPlacePickerView\n<<boundary>>" as FPPV
boundary "MenuEditorView\n<<boundary>>" as MEV

control "JourneyController\n<<control>>" as JC
control "UserController\n<<control>>" as UC

entity "Trip\n<<entity>>" as Trip
entity "FoodPlan\n<<entity>>" as FP
entity "Menu\n<<entity>>" as Menu

database "DB" as DB

== Esamo plano užkrovimas ==
KT -> FPV : redaguoti maisto planą
FPV -> JC : getFoodPlan(tripId)
JC -> DB : query(FoodPlan by tripId)
DB --> JC : foodPlanData
JC --> FPV : showFoodPlan(foodPlanData)
FPV --> KT : rodyti planą

== Maisto vietos keitimas ==
KT -> FPV : pridėti maisto vietą
FPV -> FPPV : openPicker()
FPPV -> JC : getFoodPlaces(route, preferences)
JC -> DB : query(FoodPlace by route, preferences)
DB --> JC : foodPlaces
JC --> FPPV : foodPlaces
FPPV --> KT : rodyti pasirinkimus
KT -> FPPV : pasirinkti vietą
FPPV -> JC : addFoodPlace(tripId, placeId)
JC -> FP : addPlace(placeId)
FP --> JC : ok

== Meniu redagavimas ==
KT -> FPV : redaguoti meniu
FPV -> MEV : open(menuId)
MEV -> JC : updateMenu(menuChanges)
JC -> Menu : applyChanges(menuChanges)
Menu --> JC : ok

JC -> DB : save(foodPlan)
DB --> JC : saved
JC --> FPV : foodPlanUpdated
FPV --> KT : maisto planas atnaujintas
@enduml
