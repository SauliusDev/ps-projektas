@startuml Peržiūrėti_keliones
skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam participant {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam boundary {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam control {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam entity {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
}

title Peržiūrėti keliones — sequence diagram

actor Naudotojas as N

boundary "TripListView\n<<boundary>>" as TLV
boundary "TripDetailsView\n<<boundary>>" as TDV

control "TripListController\n<<control>>" as TLC

entity "Trip\n<<entity>>" as Trip
database "DB" as DB

== Kelionių sąrašo atidarymas ==
N -> TLV : atidaryti mano keliones
TLV -> TLC : getTrips(userId)
TLC -> DB : query(Trip by userId)
DB --> TLC : tripsData
TLC --> TLV : trips
TLV --> N : rodyti kelionių sąrašą

== Kelionės peržiūra ==
N -> TLV : pasirinkti kelionę
TLV -> TLC : getTripDetails(tripId)
TLC -> Trip : load(tripId)
Trip --> TLC : trip
TLC --> TDV : showTrip(trip)
TDV --> N : rodyti kelionės detales

opt Filtravimas pagal statusą/datą
  N -> TLV : filtruoti(status, dateRange)
  TLV -> TLC : filterTrips(criteria)
  TLC -> DB : query(Trip by criteria)
  DB --> TLC : filteredTrips
  TLC --> TLV : filteredTrips
  TLV --> N : atnaujintas sąrašas
end
@enduml
