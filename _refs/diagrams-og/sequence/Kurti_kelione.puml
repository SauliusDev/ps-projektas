@startuml Kurti_kelione
skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam participant {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam boundary {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam control {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam entity {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
}

title Kurti kelionę — sequence diagram

actor Keliautojas as KT

boundary "CreateJourneyView\n<<boundary>>" as CJV
boundary "AddFriendView\n<<boundary>>" as AFV
boundary "JourneyParamsView\n<<boundary>>" as JPV
boundary "JourneyOverviewView\n<<boundary>>" as JOV

control "TripListController\n<<control>>" as TLC
control "JourneyController\n<<control>>" as JC
control "RouteController\n<<control>>" as RC
control "UserController\n<<control>>" as UC

entity "Trip\n<<entity>>" as Trip
entity "Route\n<<entity>>" as Route
entity "Preferences\n<<entity>>" as Prefs

database "DB" as DB

== Inicializacija ==
KT -> CJV : atidaryti kelionės kūrimą
CJV -> TLC : initCreateJourney()
TLC -> Trip : new Trip()
Trip --> TLC : trip
TLC --> CJV : showForm(trip)
CJV --> KT : rodyti formą

== Draugo pridėjimas (pasirenkamas) ==
KT -> CJV : pridėtiDraugą()
CJV -> AFV : open()
AFV --> KT : rodyti draugų paiešką
KT -> AFV : pasirinkti draugą
AFV -> UC : findUser(email)
UC -> DB : query(User)
DB --> UC : userData
UC --> AFV : userFound
AFV -> TLC : addTraveler(trip, friendId)
TLC -> Trip : addTraveler(friendId)
Trip --> TLC : ok
TLC --> CJV : travelerAdded

== Parinkčių konfigūracija ==
KT -> JPV : konfigūruoti parinktis
JPV -> JC : loadPreferences(travelerId)
JC -> DB : query(Preferences)
DB --> JC : preferencesData
JC --> JPV : preferences
JPV --> KT : rodyti parinktis
KT -> JPV : patvirtinti parinktis
JPV -> JC : saveParams(params)
JC -> Prefs : merge(prefs1, prefs2)
Prefs --> JC : mergedPrefs

== Maršruto generavimas ==
JC -> RC : generateRoute(mergedPrefs, dates)
RC -> DB : getAttractions(city, prefs)
DB --> RC : attractionsList
RC -> RC : score(attractions, mergedPrefs)
RC -> RC : rankByScore()
RC -> RC : fitToTimeWindow(N)
RC -> Route : new Route(rankedAttractions)
Route --> RC : route
RC --> JC : route
JC -> Trip : setRoute(route)
Trip --> JC : ok
JC --> JPV : routeReady

== Maisto plano siūlymas ==
JC -> JOV : showOverview(trip)
JOV --> KT : rodyti kelionės apžvalgą\n[siūlyti maisto planą?]

alt Sutinka generuoti maisto planą
  KT -> JOV : generuotiMaistoPlaną()
  JOV -> JC : generateFoodPlan(trip)
  JC -> DB : getFoodPlaces(route)
  DB --> JC : foodPlaces
  JC -> Trip : setFoodPlan(foodPlan)
  Trip --> JC : ok
  JC --> JOV : foodPlanReady
end

JC -> DB : save(trip)
DB --> JC : saved
JOV --> KT : kelionė sėkmingai sukurta

@enduml
