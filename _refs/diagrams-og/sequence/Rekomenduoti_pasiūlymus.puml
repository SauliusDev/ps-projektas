@startuml Rekomenduoti_pasiūlymus
skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam participant {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam boundary {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam control {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam entity {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
}

title Rekomenduoti pasiūlymus — sequence diagram

actor Naudotojas as N

boundary "MainView\n<<boundary>>" as MV
boundary "RecommendedDealsView\n<<boundary>>" as RDV

control "DealController\n<<control>>" as DC
control "UserController\n<<control>>" as UC

entity "Preferences\n<<entity>>" as Prefs
entity "Deal\n<<entity>>" as Deal

database "DB" as DB

== Rekomendacijų užklausa ==
N -> MV : gauti rekomenduojamus pasiūlymus
MV -> UC : getUserProfile(userId)
UC -> DB : query(User + Preferences)
DB --> UC : profileData
UC --> DC : recommendDeals(profileData)

== Rekomendacijų skaičiavimas ==
DC -> Prefs : extractCriteria(profileData)
Prefs --> DC : criteria
DC -> DB : query(Deal candidates by criteria)
DB --> DC : dealCandidates
DC -> DC : scoreByPreferences(candidates, criteria)
DC -> DC : rankByScore()
DC -> Deal : markTop(N)
Deal --> DC : topDeals

== Rezultato pateikimas ==
DC --> RDV : showRecommendations(topDeals)
RDV --> N : rodyti rekomenduojamus pasiūlymus
@enduml
