@startuml Peržiūrėti_pasiūlymus
skinparam style strictuml
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipant underline
skinparam participant {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}
skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam boundary {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam control {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
}
skinparam entity {
  BackgroundColor #FFF9C4
  BorderColor #F57F17
}
skinparam database {
  BackgroundColor #FCE4EC
  BorderColor #880E4F
}

title Peržiūrėti pasiūlymus — sequence diagram

actor Svečias as SV

boundary "MainView\n<<boundary>>" as MV
boundary "DealsView\n<<boundary>>" as DV

control "DealController\n<<control>>" as DC
control "SavedDealsController\n<<control>>" as SDC
control "UserController\n<<control>>" as UC

entity "Deal\n<<entity>>" as Deal
entity "SavedDeals\n<<entity>>" as SD

database "DB" as DB

== Pasiūlymų sąrašo peržiūra ==
SV -> MV : peržiūrėti pasiūlymus
MV -> DC : getDeals()
DC -> DB : query(Deal active)
DB --> DC : dealsData
DC --> DV : showDeals(dealsData)
DV --> SV : rodyti pasiūlymų sąrašą

== Pasiūlymo detalės ==
SV -> DV : pasirinkti pasiūlymą
DV -> DC : getDealDetails(dealId)
DC -> Deal : load(dealId)
Deal --> DC : deal
DC --> DV : dealDetails
DV --> SV : rodyti pasiūlymo detales

== Pasiūlymo išsaugojimas ==
SV -> DV : išsaugoti pasiūlymą
DV -> UC : checkSession()
UC --> DV : sessionStatus

alt Prisijungęs naudotojas
  DV -> SDC : saveDeal(userId, dealId)
  SDC -> SD : add(dealId)
  SD --> SDC : ok
  SDC -> DB : save(savedDeal)
  DB --> SDC : saved
  SDC --> DV : savedDealAdded
  DV --> SV : pasiūlymas išsaugotas
else Neprisijungęs svečias
  DV --> SV : reikia prisijungti
end
@enduml
