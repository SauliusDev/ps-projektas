@startuml kurti_kelione_merge_test
skinparam style strictuml
skinparam swimlane {
  BorderColor #555
}
skinparam activity {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
  ' NOTE: PlantUML DiamondBackgroundColor is GLOBAL — applies to both
  ' decision diamonds (have [guard] labels) and merge diamonds (no labels).
  ' There is no per-instance diamond color override in any PlantUML version.
  ' Convention used here: guard labels = decision, no labels = merge.
  DiamondBackgroundColor #FFB300
  DiamondBorderColor #BF6900
}

|Keliautojas|
start
:Pasirinkti „Kurti kelionę"\nmygtuką;

|Naudotojo posistemė|
if () then ([Keliautojas nematęs tutorial lango])
  :Rodyti tutorial langą;
else ([else])
endif

:Rodyti pridėti draugą\nkaip keliautoją langą;

|Keliautojas|
:Pasirinkti ar keliautu su draugu;

if () then ([pasirinko prideti drauga])

  |Naudotojo posistemė|
  :Prideti drauga\nkaip keliautoja;
  :Tikrinti ar yra issaugotu\nindvidualiu parinkciu;

  if () then ([yra])
    :Pasirinkti specifines\nkelionės parinktis;
  else ([else])
    :Pateikti ar nori\nsujunti pasirinktis;
    |Keliautojas|
    :Pasirinkti sujungti\npasirinktis;
    if () then ([sujungti])
      |Naudotojo posistemė|
      :Sujungti dvieju keliautojų\nparinktis;
    else ([else])
      |Naudotojo posistemė|
      :Pasirinkti specifines\nkelionės parinktis;
    endif
  endif

else ([else])
endif

|Keliautojas|
if () then ([Nori sudaryti savo lankymo objektus])
  |Naudotojo posistemė|
  :Pasirinkti kelionės objektus;
else ([else])
  |Keliautojas|
  :Pasirinkti sugeneruoti\nlankytinas vietas;
  |Naudotojo posistemė|
  :Surinkti visų keliautojų\npreferencijas iš profilių;
  if () then ([1 keliautojas])
    :Naudoti vieno keliautojo\npreferencijų profilį;
  else ([else])
    :Sudėti kategorinius kintamuosius\nį vieną masyvą;
    :Apskaičiuoti vidurkį\ninteger tipo kintamųjų;
    :Suformuoti bendrą\npreferencijų profilį;
  endif
  :Gauti lankytinų vietų sąrašą;
  :Apskaičiuoti kategorinių kintamųjų\nsutapimą. match(P, P_place);
  :Apskaičiuoti integer tipo\nkintamųjų skirtumą;
  :Normalizuoti individuolius\npreferences 0-100;
  :Išvesti bendrą heuristinį\nkintamąjį. sum(norm_p_match)/count;
  :Reitinguoti vietas\npagal balą B (mažėjimo tvarka);
  :Parinkti N geriausių vietų\n(N = keliautojo pasirinktas skaičius);
  :Sudaryti maršruta;
endif

:Tikrinti ar telpa į laiką\nsum(*activity_time);

if () then ([parodytas maisto plano generavimo pasiūlymas\nir planas telpa į laiką])
  :Rodyti sėkmingai sugeneruotos\nkelionės plana apžiūrą;
  stop
else ([else])
  if () then ([jei netelpa])
    :Rodyti siūlyti mažinti\nvietų skaičių langą;
    |Keliautojas|
    :Pasirinkti mažesnį\nkelionių skaičių;
  else ([else])
    |Naudotojo posistemė|
    :Rodyti siūlyti\ngeneruoti maisto planą;
    |Keliautojas|
    :Sugeneruoti maisto planą;
  endif
endif

@enduml
